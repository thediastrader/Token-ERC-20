# Required for WalletConnect modal (get one free at https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Optional: override the default Base Sepolia public RPC
# VITE_RPC_URL=https://sepolia.base.org

# Base Builder Code (ERC-8021) — appended as dataSuffix on every write transaction
# Get yours at https://onchainsummer.xyz or the Base Builder program
VITE_BUILDER_CODE=your_builder_code_here
